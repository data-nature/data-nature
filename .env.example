# ── Google Earth Engine ───────────────────────────────────────────────────────
# Required for the satellite ingest pipeline (src/data_nature/ingest/).
#
# Option A — service account (recommended for CI / Streamlit Cloud):
#   1. Create a GCP project and enable the Earth Engine API.
#   2. Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
#   3. Register it at https://code.earthengine.google.com/register
#   4. Download a JSON key — that file is GEE_PRIVATE_KEY_PATH below.
#
# Option B — interactive login (local dev only):
#   Leave both vars below empty and run `earthengine authenticate` once in your
#   terminal.  The pipeline will call ee.Authenticate() automatically.

GEE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# Path to the downloaded JSON key file (absolute or relative to project root)
GEE_PRIVATE_KEY_PATH=./gee-credentials.json
# GCP project ID linked to your Earth Engine quota
GEE_PROJECT_ID=your-gcp-project-id

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Required for the RAG AI-generated answers page (app/pages/7_RAG.py).
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ── App settings ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# Google Earth Engine service account credentials
# Get this from https://developers.google.com/earth-engine/guides/service_account
GEE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GEE_PRIVATE_KEY_PATH=./gee-credentials.json

# Optional: project ID for billing/quota
GEE_PROJECT_ID=your-gcp-project-id

# App settings
APP_ENV=development
LOG_LEVEL=INFO